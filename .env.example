# ============================================================
# FaultTreeAI 环境配置文件
# 请复制此文件为 .env 并填写真实值
# ============================================================

# ─── 数据库配置 ───
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123456
DB_NAME=faulttree

# ─── LLM Provider: ollama | minimax | openai | anthropic | azure_openai ───
# 默认使用 MiniMax，失败时仍走 MiniMax（避免未部署 Ollama 时 404）
LLM_PROVIDER=minimax
LLM_FALLBACK_PROVIDER=minimax

# ─── Ollama（本地模型，推荐开发环境） ───
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── MiniMax API ───
# MiniMax API Key（从 https://platform.minimax.io/user-center/basic-information/interface-key 获取）
MINIMAX_API_KEY=your_minimax_api_key_here
# MiniMax Group ID
MINIMAX_GROUP_ID=your_group_id
# MiniMax 模型（当前账号可用）
MINIMAX_MODEL=MiniMax-M2
# MiniMax Embedding 模型
MINIMAX_EMBED_MODEL=embo-01

# ─── OpenAI API（备选） ───
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ─── Anthropic（备选） ───
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── Azure OpenAI（企业备选） ───
AZURE_OPENAI_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-06-01

# ─── Embedding 配置 ───
EMBED_PROVIDER=minimax
EMBED_MODEL=embo-01
EMBED_DIM=1024

# ─── 生成参数 ───
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
MAX_RETRY=3

# ─── 文件存储 ───
MANUALS_PATH=data/manuals
SAMPLES_PATH=data/samples
