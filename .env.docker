# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=faulttree123
DB_NAME=faulttree

# MiniMax API (国内版) - 使用占位符，真实值请在本地填写
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
MINIMAX_MODEL=MiniMax-M2
MINIMAX_BASE_URL=https://api.minimaxi.com

# Ollama 本地模型（开发首选，零成本）
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# LLM Provider 配置
LLM_PROVIDER=ollama          # 开发环境用 ollama（本地），生产可选 minimax
LLM_FALLBACK_PROVIDER=minimax  # 主 Provider 失败时的自动回退

# Embedding 使用 Ollama (本地免费)
EMBED_PROVIDER=ollama

# Vector Database
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# File Storage
MANUALS_PATH=./data/manuals
