# ============================================================
# Git 忽略规则
# ============================================================

# Python
__pycache__/
*.py[cod]
*.pyd
*.pdb
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# 虚拟环境
venv/
env/
.venv/
.env

# FastAPI / Uvicorn
*.log
logs/
*.pid

# 数据库（敏感信息）
*.db
*.sqlite
*.sqlite3
data/chroma_db/

# 向量数据（本地存储，不需要提交）
data/manuals/
# data/samples/ - 示例知识库（可提交）

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 测试
.pytest_cache/
.coverage
htmlcov/

# 文档生成
site/

# 大文件（视频、模型）
*.bin
*.onnx
*.gguf
*.safetensors
*.pt           # YOLO 模型权重文件
yolo*.pt
data/models/   # YOLO 模型目录
vision_api_temp/  # 临时重命名的目录

# 环境变量（包含密钥）
.env

# PostgreSQL 数据目录（服务器上才需要）
postgresql/
pgdata/

# Node（前端）
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Windows 特殊文件名（避免误生成导致 Git 报错）
NUL
